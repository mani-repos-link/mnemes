APP_ADDR=:8080
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
VITE_API_BASE_URL=http://localhost:8080
PROVIDER_HTTP_REFERER=http://localhost:5173
PROVIDER_APP_TITLE=Mnemes

DATABASE_URL=file:../../data/chatbot.sqlite

# Providers (openrouter,huggingface)
DEFAULT_CHAT_PROVIDER=openrouter
DEFAULT_EMBEDDING_PROVIDER=openrouter

# Providers keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Models
CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Context and memory
# Max tokens the chat model may return.
MAX_RESPONSE_TOKENS=20000
# Memory strategy: summary, rag-vector, rag-vectorless, or none.
CONTEXT_MEMORY_MODE=rag-vectorless
# Keep this many newest messages raw; older messages become memory after this limit.
CONTEXT_MEMORY_TRIGGER_MESSAGE_LIMIT=10
# Wait for this many overflow messages before compacting/indexing another memory batch.
CONTEXT_MEMORY_BUFFER_MESSAGE_LIMIT=7
# Max chars kept per indexed/retrieved memory snippet.
MEMORY_MAX_CHARS=100000
# Max older memory snippets retrieved for RAG modes.
RETRIEVAL_TOP_K=8
# Minimum vector similarity score for rag-vector retrieval.
RETRIEVAL_MIN_SCORE=0.72

# Read-only assistant tools for local project inspection.
TOOLS_ENABLED=true
# Relative paths are resolved from this .env file location.
TOOL_WORKSPACE_ROOT=.
# Max tool calls an assistant answer may make before returning a final response.
MAX_TOOL_ITERATIONS=3
# Max characters returned from each tool result.
MAX_TOOL_OUTPUT_CHARS=12000
# Allow read-only public web tools: fetch_url, read_llms_txt, crawl_site.
INTERNET_TOOLS_ENABLED=true
# HTTP timeout for read-only internet tools.
TOOL_NETWORK_TIMEOUT_SECONDS=10
# Max bytes read per fetched URL.
MAX_TOOL_NETWORK_BYTES=300000
# Max same-site pages crawl_site may fetch.
TOOL_CRAWL_MAX_PAGES=5

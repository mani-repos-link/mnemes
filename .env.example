APP_ADDR=:8080
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
VITE_API_BASE_URL=http://localhost:8080

DATABASE_URL=file:../../data/chatbot.sqlite
SQLITE_VEC_ENABLED=true

# Providers
DEFAULT_CHAT_PROVIDER=openrouter
DEFAULT_EMBEDDING_PROVIDER=huggingface
DEFAULT_IMAGE_PROVIDER=
DEFAULT_VIDEO_PROVIDER=

# Providers keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Models
CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free
HUGGINGFACE_CHAT_MODEL=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

MAX_CONTEXT_TOKENS=12000
MAX_RESPONSE_TOKENS=2000
RECENT_MESSAGE_LIMIT=20
ENABLE_SUMMARIES=true
ENABLE_RETRIEVAL=true
RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.72

STREAM_HEARTBEAT_SECONDS=15
TOOLS_ENABLED=false
MAX_TOOL_ITERATIONS=5
